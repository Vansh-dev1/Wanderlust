<% layout("layouts/boilerplate.ejs") %>

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <a href="/listing" class="btn btn-sm btn-outline-secondary mb-4">
                <i class="bi bi-arrow-left me-1"></i> Back to Listings
            </a>

            <% if(listing.image && listing.image.url) { %>
                <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="wl-show-img mb-4">
            <% } %>

            <h1 class="wl-heading"><%= listing.title %></h1>
            <p class="text-muted mb-4">
                <i class="bi bi-geo-alt me-1"></i><%= listing.location %>, <%= listing.country %>
            </p>

            <div class="wl-detail-box mb-4">
                <p class="mb-3">Owned by <%= listing.owner.username %></p>
                <p class="mb-3"><%= listing.description %></p>
                <hr>
                <p class="mb-0 wl-price fs-5">
                    <strong>&#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></strong>
                    <span class="text-muted small"> / night</span>
                </p>
            </div>

            <% if(currUser && listing.owner._id.equals(currUser._id)) { %> 
            <div class="d-flex gap-2">
                <a href="/listing/<%= listing.id %>/edit" class="btn wl-btn-secondary">
                    <i class="bi bi-pencil me-1"></i> Edit
                </a>
                <form action="/listing/<%= listing.id %>?_method=DELETE" method="post">
                    <button type="submit" class="btn btn-outline-danger"
                        onclick="return confirm('Delete this listing?')">
                        <i class="bi bi-trash me-1"></i> Delete
                    </button>
                </form>
            </div>
            <% } %>
            

            <!-- Leave a Review -->
             <% if(currUser) { %> 
            <div class="wl-review-form-card mt-5">
                <h4 class="wl-section-title mb-4">
                    <i class="bi bi-star me-2"></i>Leave a Review
                </h4>
                <form action="/listing/<%= listing.id %>/reviews" method="POST">
                    <div class="mb-3">
                        <label for="comment" class="form-label">Your Comment</label>
                        <textarea name="review[comment]" id="comment" rows="4" class="form-control" placeholder="Share your experience..." required></textarea>
                    </div>
                    <div class="mb-4">
                        <label class="form-label d-block">Rating</label>
                        <div class="wl-star-rating" id="starRating">
                            <% for(let i = 5; i >= 1; i--) { %>
                                <input type="radio" name="review[rating]" id="star<%= i %>" value="<%= i %>" required>
                                <label for="star<%= i %>" title="<%= i %> star<%= i > 1 ? 's' : '' %>">
                                    <i class="bi bi-star-fill"></i>
                                </label>
                            <% } %>
                        </div>
                    </div>
                    <button type="submit" class="btn wl-btn-primary px-4">
                        <i class="bi bi-send me-1"></i> Submit Review
                    </button>
                </form>
            </div>
            <% } %>

            <!-- All Reviews -->
            <% if(listing.reviews && listing.reviews.length > 0) { %>
            <div class="mt-5">
                <h4 class="wl-section-title mb-4">
                    <i class="bi bi-chat-left-text me-2"></i>All Reviews
                    <span class="wl-review-count"><%= listing.reviews.length %></span>
                </h4>
                <div class="row g-3">
                    <% for(review of listing.reviews) { %>
                    <div class="col-md-6">
                        <div class="wl-review-card">
                            <div class="wl-review-stars mb-2">
                                <h5><%= review.author.username %></h5>
                                <% for(let i = 1; i <= 5; i++) { %>
                                    <i class="bi bi-star-fill <%= i <= review.rating ? 'wl-star-filled' : 'wl-star-empty' %>"></i>
                                <% } %>
                                <span class="wl-rating-num ms-1"><%= review.rating %>/5</span>
                            </div>
                            <p class="wl-review-comment">"<%= review.comment %>"</p>
                            <% if(review.createdAt) { %>
                            <p class="wl-review-date">
                                <i class="bi bi-calendar3 me-1"></i>
                                <%= new Date(review.createdAt).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                            </p>
                            <form action="/listing/<%= listing.id %>/reviews/<%= review.id %>?_method=DELETE" method="POST">
                                <button class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                            <% } %>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
            <% } else { %>
            <div class="wl-no-reviews mt-4">
                <i class="bi bi-chat-square-text"></i>
                <p>No reviews yet. Be the first to review!</p>
            </div>
            <% } %>

        </div>
    </div>
</div>
