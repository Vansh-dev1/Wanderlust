<% layout("layouts/boilerplate.ejs") %>

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="wl-form-card">
                <h2 class="wl-heading mb-1">Create a New Listing</h2>
                <p class="text-muted mb-4">Share your place with the world</p>

                <form action="/listing" method="post" novalidate class="needs-validation" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input type="text" name="listing[title]" class="form-control" placeholder="e.g. Cozy studio in Goa" required>
                        <div class="valid-feedback">
                            Title looks good
                        </div>
                        <div class="invalid-feedback">
                            Please enter a title
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="listing[description]" class="form-control" rows="3" placeholder="Describe your place..."></textarea>
                        <div class="valid-feedback">
                            Description looks good
                        </div>
                        <div class="invalid-feedback">
                            Please enter a description
                        </div>
                    </div>
                    <!-- <div class="mb-3">
                        <label class="form-label">Image URL</label>
                        <input type="text" name="listing[image][url]" class="form-control" placeholder="https://...">
                        <div class="valid-feedback">
                            Image URL looks good
                        </div>
                        <div class="invalid-feedback">
                            Please enter an image URL
                        </div>
                    </div> -->

                    <div class="mb-3">
                        <label class="form-label">Upload Image</label>
                        <input type="file" name="listing[image]" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Price per Night (&#8377;)</label>
                        <input type="number" name="listing[price]" class="form-control" placeholder="2500" required>
                        <div class="valid-feedback">
                            Price looks good
                        </div>
                        <div class="invalid-feedback">
                            Please enter a price
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Location</label>
                            <input type="text" name="listing[location]" class="form-control" placeholder="City / Area" required>
                            <div class="valid-feedback">
                                Location looks good
                            </div>
                            <div class="invalid-feedback">
                                Please enter a location
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Country</label>
                            <input type="text" name="listing[country]" class="form-control" placeholder="India" required>
                            <div class="valid-feedback">
                                Country looks good
                            </div>
                            <div class="invalid-feedback">
                                Please enter a country
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-2">
                        <button type="submit" class="btn wl-btn-primary">Add Listing</button>
                        <a href="/listing" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
