<% layout("layouts/boilerplate.ejs") %>
<%= success %>

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="wl-heading mb-0">All Listings</h2>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-4">
        <% for(let listing of allListing) { %>
            <div class="col">
                <a href="/listing/<%= listing._id %>" class="text-decoration-none">
                    <div class="wl-card">
                        <div class="wl-card-img-wrap">
                            <% if(listing.image && listing.image.url) { %>
                                <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
                            <% } else { %>
                                <div class="wl-card-placeholder">
                                    <i class="bi bi-image"></i>
                                </div>
                            <% } %>
                        </div>
                        <div class="wl-card-body">
                            <div class="wl-card-title"><%= listing.title %></div>
                            <div class="wl-card-location">
                                <i class="bi bi-geo-alt"></i>
                                <%= listing.location %>, <%= listing.country %>
                            </div>
                            <div class="wl-card-price">
                                <strong>&#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></strong>
                                <span>/ night</span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        <% } %>
    </div>

    <% if(allListing.length === 0) { %>
        <div class="text-center py-5 text-muted">
            <i class="bi bi-house-slash" style="font-size:3.5rem;"></i>
            <p class="mt-3">No listings yet. <a href="/listing/new">Create one!</a></p>
        </div>
    <% } %>
</div>
