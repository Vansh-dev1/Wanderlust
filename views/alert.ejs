<% layout("layouts/boilerplate.ejs") %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="wl-error-page text-center">
                <div class="wl-error-icon mb-4">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <h2 class="wl-error-title mb-3">Something went wrong</h2>
                <p class="wl-error-message mb-4"><%= message %></p>
                <a href="/listing" class="btn wl-btn-primary">
                    <i class="bi bi-arrow-left me-1"></i> Back to Listings
                </a>
            </div>
        </div>
    </div>
</div>